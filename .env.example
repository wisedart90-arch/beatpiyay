# ============================================================
#  BeatPiyay — Variables d'environnement
#  IMPORTANT : Renomme ce fichier en .env et remplis les valeurs
#  Ne JAMAIS committer le fichier .env sur Git !
# ============================================================

# --- MongoDB ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=beatpiyay

# --- JWT Auth ---
# Génère avec : openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_MOI_avec_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# --- CORS (liste des origines autorisées, séparées par virgule) ---
# En dev local :
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# En prod : CORS_ORIGINS=https://beatpiyay.com

# --- Stripe (paiements) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_MOI
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_MOI

# --- AWS S3 (stockage fichiers audio) ---
AWS_ACCESS_KEY_ID=CHANGE_MOI
AWS_SECRET_ACCESS_KEY=CHANGE_MOI
AWS_S3_BUCKET=beatpiyay-audio
AWS_S3_REGION=us-east-1

# --- App ---
APP_ENV=development
APP_VERSION=1.0.0
